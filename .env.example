# ─── Communiqué backend environment ───────────────────────────────────────────
# Copy to apps/backend/.env and fill in. `.env` is gitignored; this file is committed.

# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://communique:communique@localhost:5432/communique

# Redis (BullMQ + idempotency hot cache)
REDIS_URL=redis://localhost:6379

# Provider credential encryption.
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
# This is the ONLY secret the platform needs in env. Per-provider API keys are
# stored encrypted in the database, configured via the dashboard.
PROVIDER_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_base64_32_bytes=

# Dispatch worker
DISPATCH_CONCURRENCY=10
DISPATCH_MAX_ATTEMPTS=5
DISPATCH_BACKOFF_MS=2000
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50

# Rate limiting (per API credential, token bucket)
RATE_LIMIT_CAPACITY=120
RATE_LIMIT_REFILL_PER_SEC=2

# CORS (dashboard origin)
CORS_ORIGIN=http://localhost:5173
